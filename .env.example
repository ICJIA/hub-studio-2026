# Example env for local development — copy to .env and fill in values. KEYS ONLY here:
# real values live in the gitignored .env and must never be committed. A guard test
# (tests/unit/env-example.test.ts) fails locally if .env gains a key this file doesn't
# document — keep the two in sync.

# Demo mode: `true` makes `npm run dev` a self-contained public-demo build (in-memory
# content, demo login only, structurally zero Strapi writes) — matching the Netlify demo
# site. REMOVE the line entirely to run normal Strapi-backed dev (the check is exactly
# === 'true').
NUXT_PUBLIC_DEMO_MODE=true

# Strapi 5 API token for Strapi-backed dev (public REST scope; dev/test only). Short-lived
# tokens preferred — rotate/revoke when a dev cycle wraps.
STRAPI_API_TOKEN=

# Strapi 5 base URL override (no trailing slash). OPTIONAL — the real default is hardcoded
# in studio.config.ts and ships in every non-demo build. Set this to point a deploy at a
# different Strapi (e.g. a staging instance) without editing code — Nuxt's runtime-config
# env mechanism applies it: baked into static output at `generate` time; resolved at
# SERVER RUNTIME for the production `build` preset (the env must be present where the
# server RUNS — on Netlify set it via the UI/CLI, which reaches Functions by default;
# netlify.toml [build.environment] never reaches Functions and cannot carry it).
# Verified; CI's "Staging-host override guard" pins the behavior. Pair with a matching
# CSP connect-src host (runbook §2).
NUXT_PUBLIC_STRAPI_BASE_URL=https://v2.hub.icjia-api.cloud
